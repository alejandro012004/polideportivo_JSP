<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- =================== SERVLETS =================== -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.polideportivo.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RegistroServlet</servlet-name>
        <servlet-class>com.polideportivo.servlet.RegistroServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DisponibilidadServlet</servlet-name>
        <servlet-class>com.polideportivo.servlet.DisponibilidadServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ReservaServlet</servlet-name>
        <servlet-class>com.polideportivo.servlet.ReservaServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UsuarioServlet</servlet-name>
        <servlet-class>com.polideportivo.servlet.UsuarioServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>MensajeServlet</servlet-name>
        <servlet-class>com.polideportivo.servlet.MensajeServlet</servlet-class>
    </servlet>

    <!-- =================== MAPPINGS =================== -->
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RegistroServlet</servlet-name>
        <url-pattern>/registro</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DisponibilidadServlet</servlet-name>
        <url-pattern>/disponibilidad</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ReservaServlet</servlet-name>
        <url-pattern>/reserva</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UsuarioServlet</servlet-name>
        <url-pattern>/usuario/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>MensajeServlet</servlet-name>
        <url-pattern>/mensaje/*</url-pattern>
    </servlet-mapping>

    <!-- =================== FILTRO SESIÓN =================== -->
    <filter>
        <filter-name>FiltroSesion</filter-name>
        <filter-class>com.polideportivo.servlet.FiltroSesion</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>FiltroSesion</filter-name>
        <url-pattern>/usuario/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>FiltroSesion</filter-name>
        <url-pattern>/reserva</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>FiltroSesion</filter-name>
        <url-pattern>/mensaje/*</url-pattern>
    </filter-mapping>

    <!-- =================== PÁGINA DE INICIO =================== -->
    <welcome-file-list>
        <welcome-file>disponibilidad</welcome-file>
    </welcome-file-list>

</web-app>